<section class="section section--surface">
  <div class="container">
    <div class="section__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading fade-in">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="btn btn-outline btn-sm fade-in">
          {{ section.settings.view_all_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="collections-grid">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        {%- if col != blank -%}
          <a href="{{ col.url }}" class="collection-card fade-in" style="animation-delay:{{ forloop.index0 | times: 0.1 }}s" {{ block.shopify_attributes }}>
            {%- if col.image -%}
              <img
                src="{{ col.image | image_url: width: 800 }}"
                srcset="{{ col.image | image_url: width: 400 }} 400w,
                        {{ col.image | image_url: width: 800 }} 800w,
                        {{ col.image | image_url: width: 1200 }} 1200w"
                sizes="(max-width: 640px) calc(50vw - 20px), 25vw"
                alt="{{ col.title }}"
                loading="lazy" width="800" height="1067">
            {%- else -%}
              {%- assign first_product = col.products.first -%}
              {%- if first_product.featured_image -%}
                <img
                  src="{{ first_product.featured_image | image_url: width: 800 }}"
                  alt="{{ col.title }}"
                  loading="lazy" width="800" height="1067"
                  style="width:100%;height:100%;object-fit:cover">
              {%- else -%}
                <div style="width:100%;height:100%;background:linear-gradient(160deg,#1C1C2E 0%,#2a2a3e 100%)"></div>
              {%- endif -%}
            {%- endif -%}
            <div class="collection-card__overlay"></div>
            <div class="collection-card__content">
              <h3 class="collection-card__name">{{ col.title }}</h3>
              <p class="collection-card__count">{{ col.products_count }} products</p>
              <span class="collection-card__cta">
                Shop Now
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "settings": [
    { "type": "text",    "id": "eyebrow",        "label": "Eyebrow",       "default": "Browse by Category" },
    { "type": "text",    "id": "heading",        "label": "Heading",       "default": "Everything you need, instantly" },
    { "type": "text",    "id": "view_all_label", "label": "View all label","default": "View all" },
    { "type": "url",     "id": "view_all_url",   "label": "View all URL" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 4,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "presets": [{ "name": "Featured Collections" }]
}
{% endschema %}
