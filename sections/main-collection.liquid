<div class="container">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb__sep" aria-hidden="true">›</span>
    <span aria-current="page">{{ collection.title }}</span>
  </nav>

  {%- if collection.image -%}
    <div style="position:relative;border-radius:var(--radius-md);overflow:hidden;height:220px;margin-bottom:40px;background:var(--color-primary)">
      <img
        src="{{ collection.image | image_url: width: 1400 }}"
        srcset="{{ collection.image | image_url: width: 800 }} 800w,
                {{ collection.image | image_url: width: 1400 }} 1400w"
        sizes="100vw"
        alt="{{ collection.title }}"
        style="width:100%;height:100%;object-fit:cover;opacity:.45"
        loading="lazy">
      <div style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:var(--gutter)">
        <h1 style="font-family:var(--font-heading);color:#fff;font-size:clamp(2rem,4vw,3.5rem);font-weight:300">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p style="color:rgba(255,255,255,.7);max-width:480px;margin-top:8px;font-size:15px">{{ collection.description | strip_html | truncate: 120 }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,4vw,3.5rem);font-weight:300;margin-bottom:8px">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p style="color:var(--color-muted);margin-bottom:32px">{{ collection.description | strip_html | truncate: 200 }}</p>
    {%- endif -%}
  {%- endif -%}

  <div class="collection-layout">
    <!-- Filters Sidebar -->
    <aside class="collection-sidebar" aria-label="Filters">
      <form class="filter-form" id="filter-form" method="get">
        <!-- Sort (mobile) -->
        <div class="filter-group" style="display:none" id="mobile-sort">
          <div class="filter-group__title">Sort by</div>
          <select name="sort_by" class="sort-select" style="width:100%">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
            {%- endfor -%}
          </select>
        </div>

        <!-- Price filter -->
        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <div class="filter-group__title">{{ filter.label }}</div>

            {%- if filter.type == 'price_range' -%}
              <div style="display:flex;gap:8px;align-items:center">
                <input type="number" placeholder="Min" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}"
                  style="width:80px;padding:8px;border:1.5px solid var(--color-border);border-radius:var(--radius-sm);font-size:13px;outline:none">
                <span style="color:var(--color-muted);font-size:12px">–</span>
                <input type="number" placeholder="Max" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}"
                  style="width:80px;padding:8px;border:1.5px solid var(--color-border);border-radius:var(--radius-sm);font-size:13px;outline:none">
              </div>
            {%- else -%}
              {%- for value in filter.values -%}
                <label class="filter-option{% if value.active %} active{% endif %}">
                  <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %}>
                  {{ value.label }}
                  <span style="margin-left:auto;font-size:11px;color:var(--color-muted)">({{ value.count }})</span>
                </label>
              {%- endfor -%}
            {%- endif -%}
          </div>
        {%- endfor -%}

        <button type="submit" class="btn btn-primary btn-sm" style="width:100%">Apply Filters</button>
        {%- if collection.filters.size > 0 -%}
          <a href="{{ collection.url }}" style="display:block;text-align:center;font-size:12px;color:var(--color-muted);margin-top:8px;text-decoration:underline;text-underline-offset:3px">Clear all</a>
        {%- endif -%}
      </form>
    </aside>

    <!-- Products -->
    <div>
      <div class="collection-toolbar">
        <span class="collection-count">{{ collection.products_count }} products</span>
        <select name="sort_by" class="sort-select" onchange="window.location = '{{ collection.url }}?sort_by=' + this.value" aria-label="Sort by">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>

      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- if collection.products.size > 0 -%}
          <div class="products-grid" id="products-grid">
            {%- for product in collection.products -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="load-more">
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="btn btn-outline">Load more</a>
              {%- endif -%}
              <p style="font-size:12px;color:var(--color-muted);margin-top:16px">
                Showing {{ paginate.current_offset | plus: collection.products.size }} of {{ collection.products_count }} products
              </p>
            </div>
          {%- endif -%}
        {%- else -%}
          <div style="text-align:center;padding:80px 20px">
            <p style="font-size:48px;margin-bottom:16px;opacity:.2">📦</p>
            <h3 style="font-family:var(--font-heading);font-size:1.5rem;margin-bottom:8px">No products found</h3>
            <p style="color:var(--color-muted);margin-bottom:24px">Try adjusting your filters or browsing all products.</p>
            <a href="/collections/all" class="btn btn-primary">Browse All</a>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 }
  ]
}
{% endschema %}
