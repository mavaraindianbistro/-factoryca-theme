<section class="section section--surface">
  <div class="container">
    <div style="text-align:center;margin-bottom:clamp(32px,5vw,56px)">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="fade-in">{{ section.settings.heading | default: 'Made for real life' }}</h2>
    </div>

    <div class="ugc-feed__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="ugc-item fade-in"
          style="animation-delay:{{ forloop.index0 | times: 0.06 }}s"
          aria-label="{{ block.settings.alt | default: 'Customer photo' }}"
          {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 400 }}"
              srcset="{{ block.settings.image | image_url: width: 300 }} 300w,
                      {{ block.settings.image | image_url: width: 400 }} 400w"
              sizes="(max-width: 640px) 33vw, (max-width: 1200px) 16vw, 220px"
              alt="{{ block.settings.alt | default: 'FactoryCA product in use' }}"
              loading="lazy" width="400" height="400">
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--color-light);display:flex;align-items:center;justify-content:center">
              <span style="font-size:32px;opacity:.2">📸</span>
            </div>
          {%- endif -%}
          <div class="ugc-item__overlay">
            <svg viewBox="0 0 24 24" style="width:28px;height:28px;fill:#fff">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.instagram_handle != blank -%}
      <div class="ugc-follow">
        <a href="https://instagram.com/{{ section.settings.instagram_handle | remove: '@' }}" target="_blank" rel="noopener">
          Follow us @{{ section.settings.instagram_handle | remove: '@' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Photo Feed",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow",          "label": "Eyebrow",          "default": "Customer Creations" },
    { "type": "text", "id": "heading",          "label": "Heading",          "default": "See it in real life" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle", "default": "@factorycashop" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text",         "id": "alt",   "label": "Alt text" },
        { "type": "url",          "id": "link",  "label": "Link (product or Instagram)" }
      ]
    }
  ],
  "presets": [{ "name": "Photo Feed" }]
}
{% endschema %}
