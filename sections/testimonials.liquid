<section class="section testimonials">
  <div class="container">
    <div style="text-align:center;margin-bottom:clamp(40px,6vw,64px)">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="fade-in">{{ section.settings.heading | default: 'What our customers say' }}</h2>
    </div>

    <div style="overflow:hidden">
      <div class="testimonials__track">
        {%- for block in section.blocks -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- assign rating = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg viewBox="0 0 14 14" style="width:14px;height:14px;fill:{% if i <= rating %}var(--color-accent){% else %}var(--color-border){% endif %}">
                  <path d="M7 .5l1.75 3.6 3.75.55-2.7 2.65.63 3.7L7 9.25 3.57 11l.63-3.7L1.5 4.65l3.75-.55z"/>
                </svg>
              {%- endfor -%}
            </div>
            <blockquote class="testimonial-card__quote">"{{ block.settings.quote }}"</blockquote>
            <div class="testimonial-card__author">
              {%- if block.settings.avatar -%}
                <div class="testimonial-card__avatar">
                  <img src="{{ block.settings.avatar | image_url: width: 80 }}" alt="{{ block.settings.name }}" loading="lazy">
                </div>
              {%- else -%}
                <div class="testimonial-card__avatar">{{ block.settings.name | slice: 0 | upcase }}</div>
              {%- endif -%}
              <div>
                <div class="testimonial-card__name">{{ block.settings.name }}</div>
                {%- if block.settings.product != blank -%}
                  <div class="testimonial-card__product">Verified purchase · {{ block.settings.product }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="testimonials__nav">
      <button data-prev aria-label="Previous reviews">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="testimonials__dots" role="tablist">
        {%- for block in section.blocks -%}
          <button class="testimonials__dot{% if forloop.first %} active{% endif %}" role="tab" aria-label="Review {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
      <button data-next aria-label="Next reviews">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Love" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Thousands of happy downloads" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range",        "id": "rating",  "label": "Rating",          "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea",     "id": "quote",   "label": "Quote",           "default": "Absolutely beautiful quality. Printed perfectly and was exactly what I hoped for. Will be ordering again!" },
        { "type": "text",         "id": "name",    "label": "Customer name",   "default": "Sarah M." },
        { "type": "text",         "id": "product", "label": "Product name",    "default": "Botanical Art Print" },
        { "type": "image_picker", "id": "avatar",  "label": "Customer photo (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "quote": "These planners are absolutely stunning. The quality and design are beyond what I expected at this price point. Instant download worked flawlessly.", "name": "Emma T.", "product": "2025 Daily Planner" } },
        { "type": "review", "settings": { "rating": 5, "quote": "I purchased the art print bundle and every single piece is gorgeous. Printed beautifully on cardstock. My home office finally looks the part!", "name": "James R.", "product": "Botanical Art Bundle" } },
        { "type": "review", "settings": { "rating": 5, "quote": "The budget tracker spreadsheet literally changed how I manage money. So well designed and easy to use. Highly recommend everything from FactoryCA.", "name": "Priya K.", "product": "Budget Tracker Pro" } },
        { "type": "review", "settings": { "rating": 5, "quote": "Fast, easy, beautiful. The SVG files worked perfectly with my Cricut. The designs are so much more elegant than anything else I've found.", "name": "Michelle D.", "product": "Floral SVG Pack" } }
      ]
    }
  ]
}
{% endschema %}
