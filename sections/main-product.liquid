{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image  = current_variant.image | default: product.featured_image
-%}

<!-- Product Schema (Rich snippets) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": {{ request.origin | append: product.url | json }},
  "image": {{ featured_image | image_url: width: 800 | prepend: 'https:' | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "price": {{ current_variant.price | money_without_currency | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
  {%- if product.metafields.reviews.rating_count.value > 0 -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ product.metafields.reviews.rating.value }},
    "reviewCount": {{ product.metafields.reviews.rating_count.value }}
  }
  {%- endif -%}
}
</script>

<div class="container">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb__sep" aria-hidden="true">›</span>
    {%- if product.collections.first -%}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      <span class="breadcrumb__sep" aria-hidden="true">›</span>
    {%- endif -%}
    <span aria-current="page">{{ product.title }}</span>
  </nav>

  <div class="product-layout">
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main" id="product-main-image" tabindex="0" aria-label="Product image, scroll to zoom">
        {%- if featured_image -%}
          <img
            id="main-product-img"
            src="{{ featured_image | image_url: width: 900 }}"
            srcset="{{ featured_image | image_url: width: 600 }} 600w,
                    {{ featured_image | image_url: width: 900 }} 900w,
                    {{ featured_image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 640px) 100vw, 50vw"
            alt="{{ featured_image.alt | default: product.title | escape }}"
            fetchpriority="high"
            width="900" height="900">
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs" role="tablist" aria-label="Product images">
          {%- for image in product.images -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
              role="tab"
              aria-selected="{{ forloop.first }}"
              aria-label="View image {{ forloop.index }}">
              <img
                src="{{ image | image_url: width: 150 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy" width="72" height="72">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-info">
      <div class="product-info__type">{{ product.type | default: 'Digital Download' }}</div>
      <h1 class="product-info__title">{{ product.title }}</h1>

      {%- if product.metafields.reviews.rating_count.value > 0 -%}
        <div class="product-info__stars">
          {%- assign rating = product.metafields.reviews.rating.value | round -%}
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 14 14" style="width:14px;height:14px;fill:{% if i <= rating %}var(--color-accent){% else %}var(--color-border){% endif %}">
              <path d="M7 .5l1.75 3.6 3.75.55-2.7 2.65.63 3.7L7 9.25 3.57 11l.63-3.7L1.5 4.65l3.75-.55z"/>
            </svg>
          {%- endfor -%}
          <a href="#reviews" class="product-info__review-link">{{ product.metafields.reviews.rating_count.value }} reviews</a>
        </div>
      {%- endif -%}

      <div class="product-info__price-block">
        <span class="product-info__price" id="product-price">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s class="product-info__compare-price">{{ current_variant.compare_at_price | money }}</s>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="product-info__savings">Save {{ savings }}%</span>
        {%- endif -%}
      </div>

      <div class="product-info__divider"></div>

      {%- if product.description != blank -%}
        <div class="product-info__short-desc">
          {{ product.description | strip_html | truncate: 300 }}
        </div>
      {%- endif -%}

      <!-- Digital delivery badge -->
      <div class="product-info__digital-badge">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <div class="product-info__digital-badge-text">
          <div class="product-info__digital-badge-title">Instant Digital Download</div>
          <div class="product-info__digital-badge-sub">Files available immediately after purchase. No waiting, no shipping.</div>
        </div>
      </div>

      <!-- Variant selector -->
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div style="margin-bottom:20px">
            <div class="variant-label">{{ option.name }}</div>
            <div class="variant-buttons">
              {%- for value in option.values -%}
                <button
                  class="variant-btn{% if option.selected_value == value %} active{% endif %}"
                  data-option="{{ option.position }}"
                  data-value="{{ value | escape }}">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <!-- ATC Form -->
      {%- form 'product', product, class: 'product-atc-form', id: 'product-form' -%}
        <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">
        <button type="submit" class="atc-btn" aria-label="Add {{ product.title }} to cart">
          {%- if current_variant.available -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Add to Cart · {{ current_variant.price | money }}
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      {%- endform -%}

      <!-- Trust strip -->
      <div class="product-trust">
        <div class="product-trust__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Secure checkout
        </div>
        <div class="product-trust__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Instant delivery
        </div>
        <div class="product-trust__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Satisfaction guaranteed
        </div>
      </div>

      <!-- Accordion -->
      <div class="accordion">
        <div class="accordion__item">
          <button class="accordion__trigger" aria-expanded="false">
            Product Details
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="accordion__content">
            <div class="accordion__body">{{ product.description }}</div>
          </div>
        </div>

        <div class="accordion__item">
          <button class="accordion__trigger" aria-expanded="false">
            File Information
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="accordion__content">
            <div class="accordion__body">
              {{ product.metafields.custom.file_info | default: '<p>High-resolution digital files included. Compatible with Adobe, Canva, and standard printing software. Print at home or at your local print shop. Files are provided in PDF and/or PNG format at 300 DPI.</p>' }}
            </div>
          </div>
        </div>

        <div class="accordion__item">
          <button class="accordion__trigger" aria-expanded="false">
            How to Download
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="accordion__content">
            <div class="accordion__body">
              <p>After completing your purchase, you'll receive an email with your download link. You can also access your files anytime from your account order page. Files are available for download immediately.</p>
            </div>
          </div>
        </div>

        <div class="accordion__item">
          <button class="accordion__trigger" aria-expanded="false">
            Refund Policy
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="accordion__content">
            <div class="accordion__body">
              <p>Due to the digital nature of this product, we do not accept returns. However, if you experience any issues with your files, please contact us and we'll make it right.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sticky ATC Bar -->
<div class="sticky-atc" aria-label="Quick add to cart">
  <div class="sticky-atc__product container" style="display:flex;align-items:center;justify-content:space-between;gap:20px">
    <div style="display:flex;align-items:center;gap:14px">
      {%- if featured_image -%}
        <img class="sticky-atc__img" src="{{ featured_image | image_url: width: 96 }}" alt="{{ product.title | escape }}" loading="lazy">
      {%- endif -%}
      <div>
        <div class="sticky-atc__title">{{ product.title }}</div>
        <div class="sticky-atc__price">{{ current_variant.price | money }}</div>
      </div>
    </div>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('product-form').dispatchEvent(new Event('submit', {bubbles:true}))">
      Add to Cart
    </button>
  </div>
</div>

<!-- Related products -->
{%- if section.settings.show_related -%}
  {%- assign related_products = product.collections.first.products | where: 'id', '!=', product.id -%}
  {%- if related_products.size > 0 -%}
    <section class="section section--surface" style="margin-top:48px">
      <div class="container">
        <h2 class="section-heading fade-in" style="margin-bottom:32px">You may also like</h2>
        <div class="products-grid">
          {%- for related in related_products limit: 4 -%}
            {%- render 'product-card', product: related -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

<!-- Variant JS -->
<script>
(function() {
  const productData = {{ product | json }};
  const variantSelect = document.getElementById('variant-id');
  const priceEl = document.getElementById('product-price');
  const atcBtn = document.querySelector('.atc-btn');

  document.querySelectorAll('.variant-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const position = parseInt(this.dataset.option);
      const value = this.dataset.value;
      this.closest('.variant-buttons').querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      updateVariant();
    });
  });

  function updateVariant() {
    const selectedOptions = Array.from(document.querySelectorAll('.variant-btn.active')).map(b => b.dataset.value);
    const variant = productData.variants.find(v => {
      return selectedOptions.every((opt, i) => v['option' + (i+1)] === opt);
    });
    if (!variant) return;
    variantSelect.value = variant.id;
    if (priceEl) priceEl.textContent = formatMoney(variant.price);
    if (atcBtn) {
      atcBtn.disabled = !variant.available;
      atcBtn.innerHTML = variant.available
        ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/></svg> Add to Cart · ${formatMoney(variant.price)}`
        : 'Sold Out';
    }
  }

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }
})();
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true }
  ]
}
{% endschema %}
