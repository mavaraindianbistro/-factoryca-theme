<section class="trust-bar" aria-label="Why shop with us">
  <div class="container">
    <div class="trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item fade-in" style="animation-delay:{{ forloop.index0 | times: 0.1 }}s" {{ block.shopify_attributes }}>
          <div class="trust-bar__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'download' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              {%- when 'shield' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'star' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'refresh' -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              {%- else -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            {%- endcase -%}
          </div>
          <div>
            <div class="trust-bar__label">{{ block.settings.label }}</div>
            {%- if block.settings.desc != blank -%}
              <div class="trust-bar__desc">{{ block.settings.desc }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        { "type": "select", "id": "icon",  "label": "Icon", "options": [{"value":"download","label":"Download"},{"value":"shield","label":"Shield"},{"value":"star","label":"Star"},{"value":"refresh","label":"Returns"},{"value":"check","label":"Checkmark"}], "default": "download" },
        { "type": "text",   "id": "label", "label": "Label", "default": "Instant Download" },
        { "type": "text",   "id": "desc",  "label": "Description", "default": "Get your files immediately" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "download", "label": "Instant Download",      "desc": "Files delivered immediately after purchase" } },
        { "type": "item", "settings": { "icon": "shield",   "label": "Secure Checkout",        "desc": "256-bit SSL encryption on all orders" } },
        { "type": "item", "settings": { "icon": "star",     "label": "5-Star Quality",         "desc": "Thousands of happy customers" } },
        { "type": "item", "settings": { "icon": "refresh",  "label": "Satisfaction Guarantee", "desc": "Love it or we'll make it right" } }
      ]
    }
  ]
}
{% endschema %}
