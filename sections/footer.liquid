<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      <!-- Brand column -->
      <div>
        <div class="footer-col__logo">
          {%- if section.settings.logo -%}
            <img src="{{ section.settings.logo | image_url: height: 48 }}" alt="{{ shop.name }}" height="32" style="filter:brightness(0) invert(1)">
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </div>
        <p class="footer-col__tagline">{{ section.settings.tagline | default: 'Beautiful downloads. Instant delivery. Made with care in Canada.' }}</p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="footer-col__heading">Shop</h3>
        <nav class="footer-links" aria-label="Shop navigation">
          {%- for link in linklists[section.settings.shop_nav].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- else -%}
            <a href="/collections/all">All Products</a>
            <a href="/collections/planners">Planners</a>
            <a href="/collections/art-prints">Art Prints</a>
            <a href="/collections/templates">Templates</a>
          {%- endfor -%}
        </nav>
      </div>

      <!-- Help -->
      <div>
        <h3 class="footer-col__heading">Help</h3>
        <nav class="footer-links" aria-label="Help navigation">
          {%- for link in linklists[section.settings.help_nav].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- else -%}
            <a href="/pages/faq">FAQ</a>
            <a href="/pages/how-it-works">How It Works</a>
            <a href="/policies/refund-policy">Refund Policy</a>
            <a href="/policies/privacy-policy">Privacy Policy</a>
            <a href="/contact">Contact Us</a>
          {%- endfor -%}
        </nav>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="footer-col__heading">Stay in the loop</h3>
        <p class="footer-newsletter__label">New products, exclusive deals, creative inspiration.</p>
        {%- form 'customer', class: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter,footer">
          <div class="footer-newsletter__form">
            <input
              class="footer-newsletter__input"
              type="email" name="contact[email]"
              placeholder="your@email.com"
              autocomplete="email" required
              aria-label="Email for newsletter">
            <button type="submit" class="footer-newsletter__btn">Go →</button>
          </div>
          <p class="newsletter-msg" style="font-size:11px;margin-top:8px;color:rgba(255,255,255,.5)" aria-live="polite"></p>
        {%- endform -%}
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="site-footer__bottom">
      <p class="footer-bottom__copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-payments" aria-label="Accepted payment methods">
        <span class="footer-payments__icon">VISA</span>
        <span class="footer-payments__icon">MC</span>
        <span class="footer-payments__icon">AMEX</span>
        <span class="footer-payments__icon">PP</span>
        <span class="footer-payments__icon">APPLE</span>
      </div>
      <nav class="footer-bottom__legal" aria-label="Legal links">
        <a href="{{ shop.privacy_policy.url }}">Privacy</a>
        <a href="{{ shop.terms_of_service.url }}">Terms</a>
        <a href="{{ shop.refund_policy.url }}">Refunds</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "limit": 1,
  "settings": [
    { "type": "image_picker", "id": "logo",         "label": "Logo (white version)" },
    { "type": "text",         "id": "tagline",      "label": "Tagline",             "default": "Beautiful downloads. Instant delivery. Made with care in Canada." },
    { "type": "link_list",    "id": "shop_nav",     "label": "Shop links menu" },
    { "type": "link_list",    "id": "help_nav",     "label": "Help links menu" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
