<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      <!-- Brand column -->
      <div>
        <div class="footer-col__logo">
          {%- if section.settings.logo -%}
            <img src="{{ section.settings.logo | image_url: height: 48 }}" alt="{{ shop.name }}" height="32" style="filter:brightness(0) invert(1)">
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </div>
        <p class="footer-col__tagline">{{ section.settings.tagline | default: 'Beautiful downloads. Instant delivery. Made with care in Canada.' }}</p>
        <div class="footer-social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.27 8.27 0 0 0 4.84 1.56V6.79a4.85 4.85 0 0 1-1.07-.1z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="footer-col__heading">Shop</h3>
        <nav class="footer-links" aria-label="Shop navigation">
          {%- for link in linklists[section.settings.shop_nav].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- else -%}
            <a href="/collections/all">All Products</a>
            <a href="/collections/planners">Planners</a>
            <a href="/collections/art-prints">Art Prints</a>
            <a href="/collections/templates">Templates</a>
          {%- endfor -%}
        </nav>
      </div>

      <!-- Help -->
      <div>
        <h3 class="footer-col__heading">Help</h3>
        <nav class="footer-links" aria-label="Help navigation">
          {%- for link in linklists[section.settings.help_nav].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- else -%}
            <a href="/pages/faq">FAQ</a>
            <a href="/pages/how-it-works">How It Works</a>
            <a href="/policies/refund-policy">Refund Policy</a>
            <a href="/policies/privacy-policy">Privacy Policy</a>
            <a href="/contact">Contact Us</a>
          {%- endfor -%}
        </nav>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="footer-col__heading">Stay in the loop</h3>
        <p class="footer-newsletter__label">New products, exclusive deals, creative inspiration.</p>
        {%- form 'customer', class: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter,footer">
          <div class="footer-newsletter__form">
            <input
              class="footer-newsletter__input"
              type="email" name="contact[email]"
              placeholder="your@email.com"
              autocomplete="email" required
              aria-label="Email for newsletter">
            <button type="submit" class="footer-newsletter__btn">Go →</button>
          </div>
          <p class="newsletter-msg" style="font-size:11px;margin-top:8px;color:rgba(255,255,255,.5)" aria-live="polite"></p>
        {%- endform -%}
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="site-footer__bottom">
      <p class="footer-bottom__copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-payments" aria-label="Accepted payment methods">
        <span class="footer-payments__icon">VISA</span>
        <span class="footer-payments__icon">MC</span>
        <span class="footer-payments__icon">AMEX</span>
        <span class="footer-payments__icon">PP</span>
        <span class="footer-payments__icon">APPLE</span>
      </div>
      <nav class="footer-bottom__legal" aria-label="Legal links">
        <a href="{{ shop.privacy_policy.url }}">Privacy</a>
        <a href="{{ shop.terms_of_service.url }}">Terms</a>
        <a href="{{ shop.refund_policy.url }}">Refunds</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "limit": 1,
  "settings": [
    { "type": "image_picker", "id": "logo",         "label": "Logo (white version)" },
    { "type": "text",         "id": "tagline",      "label": "Tagline",             "default": "Beautiful downloads. Instant delivery. Made with care in Canada." },
    { "type": "link_list",    "id": "shop_nav",     "label": "Shop links menu" },
    { "type": "link_list",    "id": "help_nav",     "label": "Help links menu" },
    { "type": "url",          "id": "instagram_url","label": "Instagram URL" },
    { "type": "url",          "id": "pinterest_url","label": "Pinterest URL" },
    { "type": "url",          "id": "tiktok_url",   "label": "TikTok URL" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
