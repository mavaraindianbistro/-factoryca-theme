<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <!-- SEO -->
  <title>
    {%- if template == 'index' -%}{{ shop.name }} — {{ settings.seo_tagline | default: 'Beautiful downloads. Instant delivery.' }}
    {%- elsif page_title -%}{{ page_title }} — {{ shop.name }}
    {%- else -%}{{ shop.name }}
    {%- endif -%}
  </title>
  <meta name="description" content="{{ page_description | default: settings.seo_description | escape }}">

  <!-- Open Graph -->
  <meta property="og:site_name"   content="{{ shop.name }}">
  <meta property="og:url"         content="{{ canonical_url }}">
  <meta property="og:title"       content="{{ page_title | default: shop.name }}">
  <meta property="og:description" content="{{ page_description | default: settings.seo_description }}">
  <meta property="og:type"        content="website">
  {%- if page_image -%}
    <meta property="og:image"       content="{{ page_image | image_url: width: 1200 }}">
  {%- elsif settings.share_image -%}
    <meta property="og:image"       content="{{ settings.share_image | image_url: width: 1200 }}">
  {%- endif -%}
  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com">

  <!-- Favicon -->
  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180 }}">
  {%- endif -%}

  <!-- CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- Content Security Policy headers are set server-side -->
  {%- liquid
    assign swatch_translation = 'general.color.names' | t
  -%}

  <!-- Shopify required -->
  {{ content_for_header }}

  <!-- Schema.org for shop -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
  }
  </script>
</head>
<body class="template-{{ template | replace: '.', '-' }}">
  <a href="#main" class="visually-hidden" style="position:fixed;top:8px;left:8px;z-index:9999;background:var(--color-accent);color:#fff;padding:8px 16px;border-radius:4px;font-size:13px;font-weight:600;transform:translateY(-120%);transition:transform .2s" onfocus="this.style.transform='translateY(0)'" onblur="this.style.transform='translateY(-120%)'">Skip to content</a>

  <!-- Cart overlay -->
  <div class="cart-overlay" id="cart-overlay" aria-hidden="true"></div>

  <!-- Cart Drawer -->
  {%- render 'cart-drawer' -%}

  <!-- Search Overlay -->
  <div class="search-overlay" id="search-overlay" role="dialog" aria-modal="true" aria-label="Search">
    <div class="search-box">
      <div class="search-box__input-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-muted);margin-right:12px"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input class="search-box__input" type="text" placeholder="Search for planners, art prints, templates…" autocomplete="off" spellcheck="false">
        <button onclick="document.getElementById('search-overlay').classList.remove('open');document.body.style.overflow=''" style="color:var(--color-muted);font-size:20px;padding:4px 8px;margin-left:8px" aria-label="Close search">×</button>
      </div>
      <div class="search-results" role="listbox"></div>
    </div>
  </div>

  <!-- Announcement Bar -->
  {%- section 'announcement-bar' -%}

  <!-- Header -->
  {%- section 'header' -%}

  <!-- Mobile Menu -->
  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--color-border)">
      <span style="font-family:var(--font-heading);font-size:1.4rem;font-weight:600">Menu</span>
      <button class="mobile-menu-toggle" aria-expanded="true" aria-controls="mobile-menu" style="font-size:24px;color:var(--color-muted)">×</button>
    </div>
    <div style="padding:24px">
      {%- for link in linklists[settings.main_nav_handle].links -%}
        <a href="{{ link.url }}" style="display:block;padding:14px 0;font-size:16px;font-family:var(--font-heading);border-bottom:1px solid var(--color-border);color:var(--color-text)">{{ link.title }}</a>
      {%- endfor -%}
    </div>
  </nav>

  <main id="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {%- section 'footer' -%}

  <!-- JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script>document.documentElement.classList.remove('no-js');</script>

  <!-- Mobile menu styles (inline — tiny) -->
  <style>
    .mobile-menu {
      position: fixed; top: 0; left: 0; bottom: 0;
      width: min(320px, 85vw);
      background: var(--color-surface);
      box-shadow: 4px 0 24px rgba(0,0,0,.12);
      z-index: 500;
      transform: translateX(-100%);
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
      overflow-y: auto;
    }
    .mobile-menu.open { transform: none; }
    @media (min-width: 641px) { .mobile-menu-toggle.header-mobile { display: none; } }
  </style>
</body>
</html>
