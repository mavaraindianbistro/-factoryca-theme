{%- comment -%}
  Product Card Snippet
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign first_variant = product.first_available_variant | default: product.variants.first
  assign has_hover_image = false
  if product.images.size > 1
    assign has_hover_image = true
  endif
  assign is_on_sale = false
  if first_variant.compare_at_price > first_variant.price
    assign is_on_sale = true
  endif
  assign product_type_slug = product.type | downcase | replace: ' ', '-'
-%}

<article class="product-card fade-in" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__media" tabindex="-1" aria-hidden="true">
    {%- if is_on_sale -%}
      <span class="product-card__badge">Sale</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="product-card__badge">New</span>
    {%- endif -%}

    {%- if product.featured_image -%}
      <img
        class="product-card__img product-card__img--primary"
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                {{ product.featured_image | image_url: width: 600 }} 600w,
                {{ product.featured_image | image_url: width: 800 }} 800w"
        sizes="(max-width: 640px) calc(50vw - 20px), (max-width: 1200px) 25vw, 340px"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        width="600" height="600">

      {%- if has_hover_image -%}
        <img
          class="product-card__img product-card__img--hover"
          src="{{ product.images[1] | image_url: width: 600 }}"
          alt="{{ product.images[1].alt | default: product.title | escape }}"
          loading="lazy"
          width="600" height="600"
          aria-hidden="true">
      {%- endif -%}
    {%- else -%}
      <div style="width:100%;height:100%;min-height:280px;background:linear-gradient(135deg,#1C1C2E 0%,#2d2d4e 60%,#1a2040 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px">
        <svg width="48" height="48" viewBox="0 0 26 48" fill="none"><rect x="0" y="8" width="4" height="32" fill="#C9A84C"/><rect x="0" y="8" width="22" height="4" fill="#C9A84C"/><rect x="0" y="22" width="16" height="4" fill="#C9A84C"/></svg>
        <span style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4)">Digital Download</span>
      </div>
    {%- endif -%}

    <button
      class="product-card__quick-add"
      data-quick-add
      data-variant-id="{{ first_variant.id }}"
      aria-label="Quick add {{ product.title | escape }}">
      + Quick Add
    </button>
  </a>

  <div class="product-card__info">
    <div class="product-card__type">{{ product.type | default: 'Digital Download' }}</div>
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    {%- assign review_count = product.metafields.reviews.rating_count | default: 0 -%}
    {%- assign review_rating = product.metafields.reviews.rating.value | default: 5.0 -%}
    {%- if review_count > 0 -%}
      <div class="product-card__stars" aria-label="{{ review_rating }} out of 5 stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 12 12"><path d="M6 .5l1.5 3 3.2.5-2.3 2.2.5 3.3L6 8.1 3.1 9.5l.5-3.3L1.3 4l3.2-.5z"/></svg>
        {%- endfor -%}
        <span class="product-card__review-count">({{ review_count }})</span>
      </div>
    {%- endif -%}

    <div class="product-card__price-row">
      <span class="product-card__price">{{ first_variant.price | money }}</span>
      {%- if is_on_sale -%}
        <s class="product-card__compare-price">{{ first_variant.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="product-card__format-tag">{{ product.type | downcase | replace: '_', ' ' | default: 'PDF' }}</span>
    </div>
  </div>
</article>
